{
  "expo": {
    "name": "DebitLens",
    "slug": "debitlens",
    "ios": {
      "bundleIdentifier": "com.debitlens.app",
      "infoPlist": {
        "NSUserNotificationUsageDescription": "We use notifications to remind you about budgets and reports."
      }
    },
    "android": {
      "package": "com.debitlens.app"
    },
    "plugins": [
      "expo-notifications",
      "expo-secure-store",
      "expo-sqlite"
 ],
    "platforms": ["ios", "android", "web"],
    "scheme": "debitlens"
  }
}

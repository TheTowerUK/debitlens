# Node / Expo
node_modules/
.expo/
.expo-shared/
dist/
web-build/
build/
npm-debug.log*
yarn-error.log*
.expo-packager/

# Metro/packager junk
*.map

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Env/Secrets
.env
.env.*
*.keystore
*.p12
*.mobileprovision
*.jks
*.der
google-services.json
GoogleService-Info.plist

# Native projects (ignore if you're using managed workflow)
android/
ios/

# append .expo/ to .gitignore if not already present
if (-not (Select-String -Path .gitignore -Pattern '^\.expo/?' -Quiet)) {
  Add-Content -Path .gitignore -Value "`n.expo/"
  Write-Host ".expo/ added to .gitignore"
} else {
  Write-Host ".expo/ already in .gitignore"
}

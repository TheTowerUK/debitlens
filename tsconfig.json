{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "src",
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "paths": {
      "screens/*": ["screens/*"],
      "navigation/*": ["navigation/*"],
      "components/*": ["components/*"],
      "*": ["*"]
    }
  },
  "include": ["src/**/*"]
}


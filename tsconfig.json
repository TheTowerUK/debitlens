{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "src",
    "jsx": "react-jsx",
    "paths": {
      "screens/*": ["screens/*"],
      "navigation/*": ["navigation/*"],
      "components/*": ["components/*"],
      "moduleResolution": "node",
      "esModuleInterop": true,
    "*": ["*"]
    }
  },
  "include": ["src/**/*"],
  "extends": "expo/tsconfig.base"
}
